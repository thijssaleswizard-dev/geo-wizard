PORT=5002
NODE_ENV=development

# Database Configuration
# Local Development (SQLite):
DB_CLIENT=sqlite3
DB_FILENAME=./geo_wizard.sqlite3

# Laravel Forge / Production (MySQL or PostgreSQL):
# DB_CLIENT=mysql2
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=forge
# DB_PASSWORD=your_forge_db_password
# DB_NAME=geo_wizard

